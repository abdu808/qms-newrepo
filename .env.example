# =====================================================
# QMS Environment Variables
# انسخ هذا الملف إلى .env وعدّل القيم
# =====================================================

# Application
NODE_ENV=production
APP_NAME="نظام إدارة الجودة - جمعية البر بمحافظة صبيا"
APP_URL=https://quality.bir-sabia.org.sa
PORT=3000

# Database (PostgreSQL)
POSTGRES_USER=qms_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=qms_db
DATABASE_URL=postgresql://qms_user:CHANGE_ME_STRONG_PASSWORD@qms-db:5432/qms_db?schema=public

# Security (مهم جداً - استخدم قيم عشوائية قوية)
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_FOR_JWT_SECRET_VERY_IMPORTANT
JWT_EXPIRES_IN=8h
REFRESH_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_FOR_REFRESH_DIFFERENT
REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=https://quality.bir-sabia.org.sa

# Default Admin (تنشأ أول مرة فقط)
ADMIN_EMAIL=admin@bir-sabia.org.sa
ADMIN_PASSWORD=Admin@2026
ADMIN_NAME=مسؤول النظام

# Email (اختياري - للإشعارات)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@bir-sabia.org.sa

# Backup
BACKUP_RETENTION_DAYS=30
