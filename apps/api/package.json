{
  "name": "qms-api",
  "version": "1.0.0",
  "description": "QMS API - Bir Sabia Charity",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "seed": "node src/seed.js",
    "studio": "prisma studio",
    "generate": "prisma generate",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.js",
    "backup": "node src/services/backup.js"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "prisma": "^5.20.0",
    "puppeteer-core": "^23.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "supertest": "^7.0.0",
    "testcontainers": "^11.14.0",
    "vitest": "^2.1.1",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=20"
  }
}
