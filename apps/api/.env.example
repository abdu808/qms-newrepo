# ============================================
# LOCAL TESTING - نسخ هذا الملف باسم .env
# ============================================

# قاعدة البيانات - من Neon.tech
DATABASE_URL="postgresql://username:password@hostname/dbname?sslmode=require"

# إعدادات تلقائية للتشغيل المحلي
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# JWT (افتراضي للتجربة المحلية)
JWT_SECRET=local-test-secret-not-for-prod
REFRESH_SECRET=local-refresh-secret-not-for-prod

# بيانات الأدمن الأولي
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=Test@2026
QM_PASSWORD=QM@2026
